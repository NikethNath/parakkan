# Copy to ".env" on the server and fill in. NEVER commit the real .env.
# Generate secrets with the commands shown in DEPLOY.md.

# Your domain (DNS A record must point to this server).
DOMAIN="app.your-outlet.com"

# PostgreSQL password.        generate: openssl rand -hex 16
POSTGRES_PASSWORD="change-me"

# Signs login session cookies. generate: openssl rand -base64 48
SESSION_SECRET="change-me"

# Encrypts the stored CRIS password (32 bytes hex). generate: openssl rand -hex 32
SECRET_KEY="change-me"

# Authorizes the hourly CRIS auto-fetch cron. generate: openssl rand -hex 24
CRON_SECRET="change-me"

# CRIS auto-fetch login (secrets). Pre-authenticated dealer link + RO SAP code.
# Anyone with the link can log into the dealer portal — keep it out of git.
CRIS_LOGIN_URL="https://cris.hpcl.co.in/HPCL/dealerlogin?ro=..."
CRIS_SAP_CODE="41028666"

# First admin login (created automatically on first boot). Use a STRONG password.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong"
