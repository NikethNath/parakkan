// HPCL Outlet — Daily Collection, Reconciliation, Attendance & Salary
// All monetary columns use Decimal for accounting integrity.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  ADMIN
}

enum PayType {
  MONTHLY
  PER_SHIFT
}

enum Product {
  MS
  HSD
}

enum Shift {
  MORNING
  EVENING
}

enum EntryStatus {
  DRAFT
  SUBMITTED
  VERIFIED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  username      String   @unique
  passwordHash  String
  role          Role     @default(EMPLOYEE)
  payType       PayType  @default(MONTHLY)
  monthlySalary Decimal  @default(0) @db.Decimal(12, 2)
  shiftRate     Decimal  @default(0) @db.Decimal(12, 2)
  extraPay      Decimal  @default(0) @db.Decimal(12, 2) // fixed pay for extra duties
  active        Boolean  @default(true)
  phone         String?
  joinedOn      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries          DailyEntry[]    @relation("EmployeeEntries")
  verifiedEntries  DailyEntry[]    @relation("VerifiedBy")
  attendance       Attendance[]
  audits           EntryAudit[]
  uploads          BankUpload[]
  salaryPayments   SalaryPayment[] @relation("EmployeeSalaryPayments")
  recordedPayments SalaryPayment[] @relation("RecordedSalaryPayments")
}

model DailyEntry {
  id           Int      @id @default(autoincrement())
  employee     User     @relation("EmployeeEntries", fields: [employeeId], references: [id])
  employeeId   Int
  businessDate DateTime @db.Date
  shift        Shift
  product      Product
  rate         Decimal  @db.Decimal(8, 2)

  // raw inputs — meter readings (litres)
  n1Open     Decimal @default(0) @db.Decimal(12, 2)
  n1Close    Decimal @default(0) @db.Decimal(12, 2)
  n2Open     Decimal @default(0) @db.Decimal(12, 2)
  n2Close    Decimal @default(0) @db.Decimal(12, 2)
  testLitres Decimal @default(0) @db.Decimal(12, 2)

  // raw inputs — cash denominations
  q2000 Int     @default(0)
  q500  Int     @default(0)
  q200  Int     @default(0)
  q100  Int     @default(0)
  q50   Int     @default(0)
  q20   Int     @default(0)
  q10   Int     @default(0)
  q5    Int     @default(0)
  coins Decimal @default(0) @db.Decimal(12, 2)

  // raw inputs — digital collections
  gpay Decimal @default(0) @db.Decimal(12, 2)
  pos  Decimal @default(0) @db.Decimal(12, 2)

  // computed snapshots (server-authoritative)
  cashTotal        Decimal @default(0) @db.Decimal(12, 2)
  oilTotal         Decimal @default(0) @db.Decimal(12, 2)
  expensesTotal    Decimal @default(0) @db.Decimal(12, 2)
  salaryTotal      Decimal @default(0) @db.Decimal(12, 2)
  creditTotal      Decimal @default(0) @db.Decimal(12, 2)
  grossLitres      Decimal @default(0) @db.Decimal(12, 2)
  netSalableLitres Decimal @default(0) @db.Decimal(12, 2)
  fuelExpected     Decimal @default(0) @db.Decimal(12, 2)
  shortExcess      Decimal @default(0) @db.Decimal(12, 2)

  status       EntryStatus @default(SUBMITTED)
  notes        String?
  submittedAt  DateTime    @default(now())
  verifiedBy   User?       @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verifiedById Int?
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  oilLines     OilLine[]
  expenseLines ExpenseLine[]
  salaryLines  SalaryLine[]
  creditLines  CreditLine[]
  audits       EntryAudit[]

  @@unique([employeeId, businessDate, shift, product])
  @@index([businessDate])
}

model OilLine {
  id        Int        @id @default(autoincrement())
  entry     DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId   Int
  name      String
  qty       Decimal    @db.Decimal(12, 3)
  unitPrice Decimal    @db.Decimal(12, 2)
  amount    Decimal    @db.Decimal(12, 2)
  bucket    OilBucket? @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  bucketId  Int?
}

// Admin-managed oil categories (e.g. 2T oil, Engine oil, Coolant). Staff type a
// free-text oil name per line; the admin classifies each into one.
model OilBucket {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  oilLines  OilLine[]
}

model ExpenseLine {
  id          Int            @id @default(autoincrement())
  entry       DailyEntry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId     Int
  description String
  amount      Decimal        @db.Decimal(12, 2)
  bucket      ExpenseBucket? @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  bucketId    Int?
}

model CreditLine {
  id         Int        @id @default(autoincrement())
  entry      DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId    Int
  customer   String
  amount     Decimal    @db.Decimal(12, 2)
  creditor   Creditor?  @relation(fields: [creditorId], references: [id], onDelete: SetNull)
  creditorId Int?
}

// Salary / advances paid out of the till during a shift. Staff type a name and
// amount per line; treated like an expense in the short/excess reconciliation.
model SalaryLine {
  id          Int        @id @default(autoincrement())
  entry       DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId     Int
  description String
  amount      Decimal    @db.Decimal(12, 2)
}

// Admin-managed master list of credit accounts (khata). Staff type a free-text
// customer per credit line; the admin maps each line to one of these.
model Creditor {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  phone       String?
  notes       String?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  creditLines CreditLine[]
}

// Admin-managed expense categories (e.g. Tea, Bank charges). Staff type a
// free-text description per expense line; the admin classifies each into one.
model ExpenseBucket {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  active          Boolean       @default(true)
  // When true, lines in this bucket are salary draws (not real expenses): they
  // still balance the drawer, but are netted out of the staff's month-end pay.
  isSalaryAdvance Boolean       @default(false)
  createdAt       DateTime      @default(now())
  expenseLines    ExpenseLine[]
}

// A salary payment / settlement recorded by the admin for an employee in a
// given month (e.g. paying out the balance owed). Multiple rows per month are
// allowed (partial payments). Net owed = earned − advances drawn − payments.
model SalaryPayment {
  id           Int      @id @default(autoincrement())
  employee     User     @relation("EmployeeSalaryPayments", fields: [employeeId], references: [id])
  employeeId   Int
  month        String // YYYY-MM
  amount       Decimal  @db.Decimal(12, 2)
  note         String?
  paidAt       DateTime @default(now())
  recordedBy   User?    @relation("RecordedSalaryPayments", fields: [recordedById], references: [id])
  recordedById Int?

  @@index([month])
  @@index([employeeId, month])
}

model EntryAudit {
  id          Int        @id @default(autoincrement())
  entry       DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId     Int
  changedBy   User       @relation(fields: [changedById], references: [id])
  changedById Int
  changedAt   DateTime   @default(now())
  field       String
  oldValue    String?
  newValue    String?
}

model Attendance {
  id         Int              @id @default(autoincrement())
  employee   User             @relation(fields: [employeeId], references: [id])
  employeeId Int
  date       DateTime         @db.Date
  shift      Shift
  status     AttendanceStatus @default(PRESENT)
  source     String           @default("AUTO") // AUTO | MANUAL
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([employeeId, date, shift])
  @@index([date])
}

model CrisDaily {
  id                 Int      @id @default(autoincrement())
  businessDate       DateTime @db.Date
  product            Product
  officialSaleAmount Decimal  @db.Decimal(14, 2)
  officialSaleLitres Decimal  @db.Decimal(14, 3)
  testLitres         Decimal  @default(0) @db.Decimal(12, 3)
  raw                Json?
  fetchedAt          DateTime @default(now())

  @@unique([businessDate, product])
}

model BankUpload {
  id           Int       @id @default(autoincrement())
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  uploadedById Int
  fileName     String
  uploadedAt   DateTime  @default(now())
  txns         BankTxn[]
}

model BankTxn {
  id             Int        @id @default(autoincrement())
  upload         BankUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  uploadId       Int
  txnDate        DateTime   @db.Date
  businessDate   DateTime   @db.Date
  amount         Decimal    @db.Decimal(14, 2)
  channel        String // GPAY | POS
  narration      String?
  matchedEntryId Int?

  @@index([businessDate])
}

model CrisCredential {
  id          Int      @id @default(autoincrement())
  encUsername String
  encPassword String
  updatedAt   DateTime @updatedAt
}
