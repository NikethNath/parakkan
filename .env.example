# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# PostgreSQL connection (matches docker-compose.yml service; host port 5433 to avoid
# clashing with a Postgres already running on 5432)
DATABASE_URL="postgresql://hpcl:hpcl@localhost:5433/hpcl?schema=public"

# Secret used to sign session JWTs (httpOnly cookie). Generate: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string"

# Secret used to encrypt CRIS credentials at rest (AES-256-GCM). 32 bytes hex.
# Generate: openssl rand -hex 32
SECRET_KEY="change-me-32-byte-hex-key"

# Default admin bootstrap (used only by the seed script on first run)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"

# Path to a Chrome/Chromium binary for the CRIS auto-fetch (Playwright).
# Optional — auto-detected if Chrome is installed in a standard location.
# CHROME_PATH="/opt/google/chrome/chrome"
